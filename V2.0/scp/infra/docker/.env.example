# SAPPHITAL SCP — Docker Compose full-stack environment
# Copy to .env: cp .env.example .env
# Generate APP_KEY: docker compose run --rm api php artisan key:generate --show
# Spec: Vol 10 Ch. 04, Ch. 07 (staging parity)

# -----------------------------------------------------------------------------
# Compose service ports (host bindings)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
MEILISEARCH_PORT=7700
API_PORT=8000

# -----------------------------------------------------------------------------
# PostgreSQL 16 (ADR-002 — shared database with RLS)
# -----------------------------------------------------------------------------
POSTGRES_USER=scp
POSTGRES_PASSWORD=scp_secret
POSTGRES_DB=scp

# -----------------------------------------------------------------------------
# Redis 7 (cache, session, queue, rate-limit prefixes)
# -----------------------------------------------------------------------------
# Leave empty for local dev without auth; set in shared/staging environments
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Meilisearch (tenant-scoped indexes per Vol 10 Ch. 04 §6)
# -----------------------------------------------------------------------------
MEILI_ENV=development
MEILI_MASTER_KEY=scp_dev_master_key_change_me

# -----------------------------------------------------------------------------
# Laravel application (api service — Docker network hostnames)
# -----------------------------------------------------------------------------
APP_NAME="SAPPHITAL SCP"
APP_ENV=staging
APP_KEY=base64:GENERATE_WITH_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lagos

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database — postgres service on scp_network
DATABASE_URL=pgsql://scp:scp_secret@postgres:5432/scp
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=scp
DB_USERNAME=scp
DB_PASSWORD=scp_secret

# Redis — redis service on scp_network
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_CLIENT=phpredis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Meilisearch — meilisearch service on scp_network
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=scp_dev_master_key_change_me
SCOUT_DRIVER=meilisearch

# Region & tenancy (ADR-011 — Nigeria-first)
SCP_PRIMARY_REGION=af-ng-lagos
SCP_DEFAULT_CURRENCY=NGN
SCP_DEFAULT_LOCALE=en_NG
SCP_DEFAULT_TIMEZONE=Africa/Lagos
SCP_PLATFORM_OS=true

# Paystack (test keys — replace for staging validation)
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Mail (log driver for staging scaffold)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@sapphital.local
MAIL_FROM_NAME="${APP_NAME}"

# Octane (FrankenPHP — production path; api service uses artisan serve for scaffold)
OCTANE_SERVER=frankenphp

# Optional observability / object storage (configure for shared staging)
# SENTRY_DSN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=scp-staging-media
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=true
