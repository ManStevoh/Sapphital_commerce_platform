{
    "name": "sapphital/content-cms",
    "description": "SAPPHITAL Content — CMS pages, blog posts, and navigation",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "sapphital/platform-identity": "@dev",
        "sapphital/platform-tenancy": "@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Content\\Cms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Content\\Cms\\CmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
