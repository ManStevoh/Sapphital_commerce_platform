{
    "name": "sapphital/commerce-catalog",
    "description": "SAPPHITAL Commerce — product catalog and inventory primitives",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "sapphital/platform-billing": "@dev",
        "sapphital/platform-tenancy": "@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Commerce\\Catalog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Commerce\\Catalog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Commerce\\Catalog\\CatalogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
