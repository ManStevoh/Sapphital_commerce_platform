{
    "name": "sapphital/platform-identity",
    "description": "SAPPHITAL Platform OS — authentication, authorization, and user management",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/auth": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "laravel/sanctum": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Platform\\Identity\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\Identity\\IdentityServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
