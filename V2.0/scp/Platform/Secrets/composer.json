{
    "name": "sapphital/platform-secrets",
    "description": "SAPPHITAL Platform OS — secrets and credential vault",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Platform\\Secrets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Platform\\Secrets\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\Secrets\\SecretsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
