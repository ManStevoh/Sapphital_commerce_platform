{
    "name": "sapphital/platform-ai",
    "description": "SAPPHITAL Platform OS — Intelligence / model gateway",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "sapphital/platform-billing": "@dev",
        "sapphital/platform-tenancy": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Platform\\Ai\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\Ai\\AiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
