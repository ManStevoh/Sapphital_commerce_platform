{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chop & Serve Theme Settings",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "primary_color": {
      "type": "string",
      "title": "Primary colour",
      "description": "Brand primary — appetite red by default.",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "default": "#9B2226"
    },
    "font_heading": {
      "type": "string",
      "title": "Heading font",
      "enum": ["Inter", "DM Sans", "Playfair Display", "Source Sans 3"],
      "default": "DM Sans"
    },
    "logo_url": {
      "type": ["string", "null"],
      "title": "Logo URL",
      "format": "uri",
      "default": null
    }
  },
  "required": ["primary_color", "font_heading"]
}
