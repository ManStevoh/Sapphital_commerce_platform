# SAPPHITAL Commerce Platform (SCP) — Laravel application environment
# Copy to .env: cp .env.example .env
#
# Traceability:
#   ADR-002  — Multi-tenancy: shared PostgreSQL + RLS (tenant_id on all tenant tables)
#   ADR-007  — Secrets via encrypted env (Phase 1); never commit credentials
#   ADR-011  — Nigeria-first data residency and regional defaults
#   ADR-023  — Platform OS repository layout (Platform/, Modules/, Connectors/, …)
#   Vol 10 Ch. 07 — Environments & configuration

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME="SAPPHITAL SCP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lagos

LOG_CHANNEL=stack
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database (ADR-002 — shared DB; RLS enforced via SET LOCAL app.tenant_id)
# Connect to local Docker Compose postgres service (Vol 10 Ch. 04)
# -----------------------------------------------------------------------------
DATABASE_URL=pgsql://scp:scp_secret@127.0.0.1:5432/scp
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=scp
DB_USERNAME=scp
DB_PASSWORD=scp_secret

# -----------------------------------------------------------------------------
# Redis (cache, session, queue — tenant-prefixed keys)
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Paystack (ADR-007 — PSP credentials via env; never commit secrets)
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Cloudflare Turnstile (ADR-008) — omit keys in local dev to disable verification
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Meilisearch (tenant-scoped indexes: tenant_{tenant_id}_products)
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=scp_dev_master_key_change_me
SCOUT_DRIVER=meilisearch

# -----------------------------------------------------------------------------
# SCP region & tenancy (ADR-011 — Nigeria-first; ADR-002 — tenant context)
# Production primary region: af-ng-lagos (Lagos, Nigeria)
# -----------------------------------------------------------------------------
SCP_PRIMARY_REGION=af-ng-lagos
SCP_DEFAULT_CURRENCY=NGN
SCP_DEFAULT_LOCALE=en_NG
SCP_DEFAULT_TIMEZONE=Africa/Lagos

# Tenant context placeholders (set per request by Tenancy middleware)
# SCP_TENANT_ID=
# SCP_TENANT_SLUG=

# Platform OS — module manager (ADR-023)
SCP_PLATFORM_OS=true

# -----------------------------------------------------------------------------
# Platform Secrets vault (ADR-007 Phase 1 — file driver; path never committed)
# -----------------------------------------------------------------------------
SECRETS_DRIVER=file
# SECRETS_FILE_PATH=

# -----------------------------------------------------------------------------
# Mail (local — log driver)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@sapphital.local
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Object storage (R2 — configure for staging/production per ADR-011)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=scp-local-media
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=true

# -----------------------------------------------------------------------------
# Observability (optional for local)
# -----------------------------------------------------------------------------
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Octane (FrankenPHP — use for local parity with production, Vol 10 Ch. 07 §9)
# -----------------------------------------------------------------------------
OCTANE_SERVER=frankenphp
