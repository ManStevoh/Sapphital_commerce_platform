{
    "name": "sapphital/connector-flutterwave",
    "description": "SAPPHITAL Flutterwave PSP connector — hosted payment link and verify",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Connectors\\Flutterwave\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Connectors\\Flutterwave\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Connectors\\Flutterwave\\FlutterwaveServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
