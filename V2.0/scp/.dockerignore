# Docker build context exclusions (SCP monorepo root)
.git
.github
.env
.env.*
!.env.example
infra/docker/.env
node_modules
vendor
apps/*/node_modules
apps/*/.next
storage/logs
storage/framework/cache
storage/framework/sessions
storage/framework/views
bootstrap/cache/*.php
.phpunit.result.cache
e2e/test-results
e2e/playwright-report
