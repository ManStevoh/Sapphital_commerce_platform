NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev fallback when not using tenant subdomain (e.g. acme.shops.sapphital.test)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=acme-store

# Cloudflare Turnstile (optional in local dev — omit to skip widget)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: skip slug lookup and use tenant UUID directly
# NEXT_PUBLIC_TENANT_ID=
